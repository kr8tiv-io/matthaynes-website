{
  "name": "matthaynes-website",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Matt Haynes personal site rebuilt as a static Astro couture editorial experience.",
  "scripts": {
    "dev": "node scripts/sync-public-assets.mjs && astro dev --host --port 4322",
    "build": "node scripts/sync-public-assets.mjs && astro build && node scripts/compat-routes.mjs",
    "preview": "node scripts/sync-public-assets.mjs && astro preview --host --port 4322",
    "astro": "astro",
    "typecheck": "astro check",
    "test": "vitest run",
    "impeccable": "impeccable detect --fast src",
    "verify": "npm run test && npm run typecheck && npm run build && npm run impeccable"
  },
  "dependencies": {
    "@astrojs/react": "5.0.4",
    "astro": "6.2.2",
    "gsap": "3.15.0",
    "lenis": "1.3.23",
    "motion": "12.38.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.0",
    "impeccable": "^2.1.8",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "main": "qa_readability.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kr8tiv-io/matthaynes-website.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kr8tiv-io/matthaynes-website/issues"
  },
  "homepage": "https://github.com/kr8tiv-io/matthaynes-website#readme"
}
